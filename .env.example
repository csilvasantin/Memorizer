# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=your_source_group_id_here

# Destination groups
TELEGRAM_GROUP_NEGOCIO=your_negocio_group_id_here
TELEGRAM_GROUP_TECNOLOGIA=your_tecnologia_group_id_here
TELEGRAM_GROUP_CREATIVIDAD=your_creatividad_group_id_here
TELEGRAM_GROUP_MISCELANEA=your_miscelanea_group_id_here

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database
DATABASE_PATH=data/memorizer.db
